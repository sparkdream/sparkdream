# Copy this file to .env and fill in credentials for the providers you
# want to test. Tests for providers with missing credentials are skipped.
#
# cp test/archival/.env.example .env

# Pinata (https://app.pinata.cloud/developers/api-keys)
PINATA_JWT=

# Filebase (https://console.filebase.com/keys)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
FILEBASE_BUCKET=

# Storacha — requires interactive login, see deploy/scripts/storacha-upload.sh
# No env vars needed; test checks `storacha whoami` instead.

# Jackal — set one of the following (vault mode preferred):
#   Vault: on-chain storage via jackal.js (requires npm install -g @jackallabs/jackal.js)
JACKAL_MNEMONIC=
#   Pin: hosted IPFS pinning (https://pin.jackalprotocol.com/keys)
JACKAL_API_KEY=

# Arweave — requires arkb + wallet file
ARWEAVE_WALLET=
